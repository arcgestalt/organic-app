#!/bin/sh

echo "🔍 Running pre-commit checks..."

# 1. Run formatter check
echo "✨ Checking formatting with Biome..."
pnpm run format
if [ $? -ne 0 ]; then
  echo "❌ Formatting failed. Please fix formatting errors before committing."
  exit 1
fi

# 2. Run lint check
echo "🛡️ Checking lints with Biome..."
pnpm run lint
if [ $? -ne 0 ]; then
  echo "❌ Lint checks failed. Please fix lint errors before committing."
  exit 1
fi

# 3. Run typecheck
echo "⌨️ Running TypeScript typecheck..."
pnpm run typecheck
if [ $? -ne 0 ]; then
  echo "❌ Typecheck failed. Please fix TypeScript errors before committing."
  exit 1
fi

echo "✅ All checks passed! Proceeding with commit."
exit 0

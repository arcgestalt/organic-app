    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "biome": "^0.3.3",
    "wrangler": "^4.101.0"
  },
  "overrides": {
    "vite": "^7"
  }
